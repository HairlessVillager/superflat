{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "superflat",
    "version": "0.1.0",
    "identifier": "com.hairlessvillager.superflat",
    "build": {
        "beforeDevCommand": {
            "script": "trunk serve",
            "cwd": ".."
        },
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": {
            "script": "trunk build --release",
            "cwd": ".."
        },
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "superflat",
                "width": 800,
                "height": 600
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
